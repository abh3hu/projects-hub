{
  "name": "projects-hub",
  "version": "1.0.0",
  "description": "Open projects and open-loop tracking dashboard for Allen.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "build:snapshot": "node scripts/build-snapshot.js",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test:unit": "node --test tests/unit.test.js",
    "test:api": "node --test tests/api.test.js",
    "test:e2e": "playwright test",
    "test:quick": "npm run test:unit && npm run test:api",
    "test": "npm run test:unit && npm run test:api && npm run test:e2e"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "supertest": "^7.1.1"
  }
}
